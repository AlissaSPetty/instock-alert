{
  "name": "pricechecker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pricechecker/api",
    "dev:web": "npm run dev --workspace @pricechecker/web",
    "dev:api": "npm run dev --workspace @pricechecker/api",
    "dev:worker": "npm run dev --workspace @pricechecker/worker",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "npm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
